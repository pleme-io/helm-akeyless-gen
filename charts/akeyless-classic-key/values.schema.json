{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "autoscaling": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "config": {
      "properties": {
        "alg": {
          "description": "Classic key algorithm: AES128GCM, AES256GCM, AES128SIV, AES256SIV, RSA1024, RSA2048, RSA3072, RSA4096, EC256, EC384",
          "minLength": 1,
          "type": "string"
        },
        "auto_rotate": {
          "description": "Whether to automatically rotate every rotation_interval days, or disable existing automatic rotation [true/false]",
          "type": "string"
        },
        "certificate_common_name": {
          "description": "Common name for generated certificate",
          "type": "string"
        },
        "certificate_country": {
          "description": "Country for generated certificate",
          "type": "string"
        },
        "certificate_digest_algo": {
          "description": "Digest algorithm to be used for the certificate key signing.",
          "type": "string"
        },
        "certificate_format": {
          "type": "string"
        },
        "certificate_locality": {
          "description": "Locality for generated certificate",
          "type": "string"
        },
        "certificate_organization": {
          "description": "Organization for generated certificate",
          "type": "string"
        },
        "certificate_province": {
          "description": "Province for generated certificate",
          "type": "string"
        },
        "certificate_ttl": {
          "description": "Certificate TTL in days",
          "type": "integer"
        },
        "delete_protection": {
          "description": "Enable delete protection",
          "type": "boolean"
        },
        "description": {
          "description": "Key description",
          "type": "string"
        },
        "expiration_event_in": {
          "description": "How many days before the expiration of the certificate would you like to be notified.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "generate_self_signed_certificate": {
          "description": "Generate a self-signed certificate",
          "type": "boolean"
        },
        "gpg_alg": {
          "description": "gpg alg: Relevant only if GPG key type selected; options: [RSA1024, RSA2048, RSA3072, RSA4096, Ed25519]",
          "type": "string"
        },
        "hash_algorithm": {
          "default": "SHA256",
          "description": "Specifies the hash algorithm used for the encryption key's operations, available options: [SHA256, SHA384, SHA512]",
          "type": "string"
        },
        "item_custom_fields": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Additional custom fields to associate with the item",
          "type": "object"
        },
        "name": {
          "description": "ClassicKey name",
          "minLength": 1,
          "type": "string"
        },
        "protection_key_name": {
          "description": "Encryption key used to protect this key",
          "type": "string"
        },
        "rotation_event_in": {
          "description": "How many days before the rotation of the item would you like to be notified",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "rotation_interval": {
          "description": "The number of days to wait between every automatic rotation (1-365)",
          "type": "string"
        },
        "tags": {
          "description": "Tags for the key",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "alg",
        "name"
      ],
      "type": "object"
    },
    "image": {
      "properties": {
        "pullPolicy": {
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "monitoring": {
      "properties": {
        "alerting": {
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "enabled": {
          "type": "boolean"
        },
        "interval": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "port": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "networkPolicy": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "pdb": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "ports": {
      "items": {
        "properties": {
          "containerPort": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "protocol": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "type": "array"
    },
    "replicaCount": {
      "default": 1,
      "type": "integer"
    },
    "resources": {
      "properties": {
        "limits": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "requests": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "secrets": {
      "properties": {
        "cert_file_data": {
          "description": "Certificate PEM data (for RSA keys)",
          "type": "string"
        },
        "key_data": {
          "description": "Key material (base64 encoded)",
          "type": "string"
        }
      },
      "type": "object"
    },
    "service": {
      "properties": {
        "ports": {
          "items": {
            "properties": {
              "name": {
                "type": "string"
              },
              "port": {
                "type": "integer"
              },
              "protocol": {
                "type": "string"
              },
              "targetPort": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "type": "array"
        },
        "type": {
          "enum": [
            "ClusterIP",
            "NodePort",
            "LoadBalancer"
          ],
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "title": "akeyless_classic_key values",
  "type": "object"
}