{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "autoscaling": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "config": {
      "properties": {
        "azure_client_id": {
          "description": "(Optional) Client id (relevant for \"cloud-service-provider\" only)",
          "type": "string"
        },
        "azure_client_secret": {
          "description": "(Optional) Client secret (relevant for \"cloud-service-provider\" only)",
          "type": "string"
        },
        "azure_tenant_id": {
          "description": "(Optional) Tenant id (relevant for \"cloud-service-provider\" only)",
          "type": "string"
        },
        "cloud_service_provider": {
          "description": "(Optional) Cloud service provider (currently only supports Azure)",
          "type": "string"
        },
        "cluster_mode": {
          "description": "Cluster Mode",
          "type": "boolean"
        },
        "comment": {
          "description": "Deprecated - use description",
          "type": "string"
        },
        "connection_type": {
          "default": "credentials",
          "description": "Type of connection to mssql database [credentials/cloud-identity/wallet/parent-target]",
          "minLength": 1,
          "type": "string"
        },
        "db_name": {
          "description": "Database name",
          "type": "string"
        },
        "db_server_name": {
          "description": "Database server name for TLS verification",
          "type": "string"
        },
        "db_type": {
          "description": "Database type: mysql, mssql, postgresql, mongodb, snowflake, oracle, cassandra, redshift, hanadb",
          "minLength": 1,
          "type": "string"
        },
        "description": {
          "description": "Target description",
          "type": "string"
        },
        "host": {
          "description": "Database hostname",
          "type": "string"
        },
        "key": {
          "description": "The name of a key that used to encrypt the target secret value (if empty, the account default protectionKey key will be used)",
          "type": "string"
        },
        "max_versions": {
          "description": "Set the maximum number of versions, limited by the account settings defaults.",
          "type": "string"
        },
        "mongodb_atlas": {
          "description": "Use MongoDB Atlas connection",
          "type": "boolean"
        },
        "mongodb_atlas_api_public_key": {
          "description": "MongoDB Atlas API public key",
          "type": "string"
        },
        "mongodb_atlas_project_id": {
          "description": "MongoDB Atlas project ID",
          "type": "string"
        },
        "mongodb_default_auth_db": {
          "description": "MongoDB default authentication database",
          "type": "string"
        },
        "mongodb_uri_options": {
          "description": "MongoDB additional URI options",
          "type": "string"
        },
        "name": {
          "description": "Target name",
          "minLength": 1,
          "type": "string"
        },
        "oracle_service_name": {
          "description": "Oracle service name",
          "type": "string"
        },
        "oracle_wallet_login_type": {
          "description": "Oracle Wallet login type (password/mtls)",
          "type": "string"
        },
        "oracle_wallet_p12_file_data": {
          "description": "Oracle wallet p12 file data in base64",
          "type": "string"
        },
        "oracle_wallet_sso_file_data": {
          "description": "Oracle wallet sso file data in base64",
          "type": "string"
        },
        "parent_target_name": {
          "description": "Name of the parent target, relevant only when connection-type is parent-target",
          "type": "string"
        },
        "port": {
          "description": "Database port",
          "type": "string"
        },
        "snowflake_account": {
          "description": "Snowflake account identifier",
          "type": "string"
        },
        "snowflake_api_private_key": {
          "description": "RSA Private key (base64 encoded)",
          "type": "string"
        },
        "snowflake_api_private_key_password": {
          "description": "The Private key passphrase",
          "type": "string"
        },
        "ssl": {
          "default": false,
          "description": "Enable SSL connection",
          "type": "boolean"
        },
        "user_name": {
          "description": "Database username",
          "type": "string"
        }
      },
      "required": [
        "connection_type",
        "db_type",
        "name"
      ],
      "type": "object"
    },
    "image": {
      "properties": {
        "pullPolicy": {
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "monitoring": {
      "properties": {
        "alerting": {
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "enabled": {
          "type": "boolean"
        },
        "interval": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "port": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "networkPolicy": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "pdb": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "ports": {
      "items": {
        "properties": {
          "containerPort": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "protocol": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "type": "array"
    },
    "replicaCount": {
      "default": 1,
      "type": "integer"
    },
    "resources": {
      "properties": {
        "limits": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "requests": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "secrets": {
      "properties": {
        "db_server_certificates": {
          "description": "Database server TLS certificates (PEM)",
          "type": "string"
        },
        "mongodb_atlas_api_private_key": {
          "description": "MongoDB Atlas API private key",
          "type": "string"
        },
        "pwd": {
          "description": "Database password",
          "type": "string"
        },
        "ssl_certificate": {
          "description": "Client SSL certificate (PEM)",
          "type": "string"
        }
      },
      "type": "object"
    },
    "service": {
      "properties": {
        "ports": {
          "items": {
            "properties": {
              "name": {
                "type": "string"
              },
              "port": {
                "type": "integer"
              },
              "protocol": {
                "type": "string"
              },
              "targetPort": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "type": "array"
        },
        "type": {
          "enum": [
            "ClusterIP",
            "NodePort",
            "LoadBalancer"
          ],
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "title": "akeyless_target_db values",
  "type": "object"
}