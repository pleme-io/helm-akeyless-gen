{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "autoscaling": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "config": {
      "properties": {
        "description": {
          "description": "Target description",
          "type": "string"
        },
        "k8s_auth_type": {
          "default": "token",
          "description": "Kubernetes auth type: token, certificate, or password",
          "type": "string"
        },
        "k8s_cluster_endpoint": {
          "description": "Kubernetes API server URL",
          "type": "string"
        },
        "k8s_cluster_name": {
          "description": "K8S cluster name",
          "type": "string"
        },
        "key": {
          "description": "The name of a key that used to encrypt the target secret value (if empty, the account default protectionKey key will be used)",
          "type": "string"
        },
        "max_versions": {
          "description": "Set the maximum number of versions, limited by the account settings defaults.",
          "type": "string"
        },
        "name": {
          "description": "Target name",
          "type": "string"
        },
        "use_gw_service_account": {
          "description": "Use gateway service account for authentication",
          "type": "boolean"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "image": {
      "properties": {
        "pullPolicy": {
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "monitoring": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "networkPolicy": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "pdb": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "replicaCount": {
      "default": 1,
      "type": "integer"
    },
    "resources": {
      "properties": {
        "limits": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "requests": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "secrets": {
      "properties": {
        "k8s_client_certificate": {
          "description": "Kubernetes client certificate (PEM)",
          "type": "string"
        },
        "k8s_client_key": {
          "description": "Kubernetes client key (PEM)",
          "type": "string"
        },
        "k8s_cluster_ca_cert": {
          "description": "Kubernetes cluster CA certificate (PEM)",
          "type": "string"
        },
        "k8s_cluster_token": {
          "description": "Kubernetes bearer token",
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "title": "akeyless_target_k8s values",
  "type": "object"
}