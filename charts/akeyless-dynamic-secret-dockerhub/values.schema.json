{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "autoscaling": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "config": {
      "properties": {
        "delete_protection": {
          "description": "Enable delete protection",
          "type": "boolean"
        },
        "description": {
          "description": "Description of the object",
          "type": "string"
        },
        "dockerhub_token_scopes": {
          "description": "Docker Hub token scopes (comma-separated)",
          "type": "string"
        },
        "dockerhub_username": {
          "description": "Docker Hub username",
          "type": "string"
        },
        "item_custom_fields": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Additional custom fields to associate with the item",
          "type": "object"
        },
        "name": {
          "description": "Dynamic secret name",
          "type": "string"
        },
        "producer_encryption_key_name": {
          "description": "Dynamic producer encryption key",
          "type": "string"
        },
        "tags": {
          "description": "Tags for the producer",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "target_name": {
          "description": "Target name associated with this producer",
          "type": "string"
        },
        "user_ttl": {
          "default": "60m",
          "description": "User TTL (e.g., 60m, 12h)",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "image": {
      "properties": {
        "pullPolicy": {
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "monitoring": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "networkPolicy": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "pdb": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "replicaCount": {
      "default": 1,
      "type": "integer"
    },
    "resources": {
      "properties": {
        "limits": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "requests": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "secrets": {
      "properties": {
        "dockerhub_password": {
          "description": "Docker Hub password or access token",
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "title": "akeyless_dynamic_secret_dockerhub values",
  "type": "object"
}