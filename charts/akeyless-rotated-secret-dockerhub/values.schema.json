{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "autoscaling": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "config": {
      "properties": {
        "authentication_credentials": {
          "default": "use-user-creds",
          "description": "Credentials to connect with: use-user-creds or use-target-creds",
          "type": "string"
        },
        "auto_rotate": {
          "description": "Whether to automatically rotate every rotation-interval days [true/false]",
          "type": "string"
        },
        "delete_protection": {
          "description": "Enable delete protection",
          "type": "boolean"
        },
        "description": {
          "description": "Description of the object",
          "type": "string"
        },
        "key": {
          "description": "Encryption key name for the secret value",
          "type": "string"
        },
        "max_versions": {
          "description": "Maximum number of versions",
          "type": "string"
        },
        "name": {
          "description": "Rotated secret name",
          "minLength": 1,
          "type": "string"
        },
        "password_length": {
          "description": "Length of the password to be generated",
          "type": "string"
        },
        "rotation_event_in": {
          "description": "How many days before the rotation of the item would you like to be notified",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "rotation_hour": {
          "description": "The hour of the rotation in UTC",
          "type": "integer"
        },
        "rotation_interval": {
          "description": "Days between every automatic key rotation (1-365)",
          "type": "string"
        },
        "tags": {
          "description": "Tags for the rotated secret",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "target_name": {
          "description": "Target name to associate",
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "name",
        "target_name"
      ],
      "type": "object"
    },
    "image": {
      "properties": {
        "pullPolicy": {
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "monitoring": {
      "properties": {
        "alerting": {
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "enabled": {
          "type": "boolean"
        },
        "interval": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "port": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "networkPolicy": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "pdb": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "ports": {
      "items": {
        "properties": {
          "containerPort": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "protocol": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "type": "array"
    },
    "replicaCount": {
      "default": 1,
      "type": "integer"
    },
    "resources": {
      "properties": {
        "limits": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "requests": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "service": {
      "properties": {
        "ports": {
          "items": {
            "properties": {
              "name": {
                "type": "string"
              },
              "port": {
                "type": "integer"
              },
              "protocol": {
                "type": "string"
              },
              "targetPort": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "type": "array"
        },
        "type": {
          "enum": [
            "ClusterIP",
            "NodePort",
            "LoadBalancer"
          ],
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "title": "akeyless_rotated_secret_dockerhub values",
  "type": "object"
}