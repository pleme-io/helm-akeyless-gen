{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "autoscaling": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "config": {
      "properties": {
        "access_expires": {
          "default": 0,
          "description": "Access expiration in Unix time (0 = no expiry)",
          "type": "integer"
        },
        "allowed_client_type": {
          "description": "limit the auth method usage for specific client types [cli,ui,gateway-admin,sdk,mobile,extension]",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "audience": {
          "description": "OAuth2 audience",
          "type": "string"
        },
        "audit_logs_claims": {
          "description": "Subclaims to include in audit logs, e.g \"--audit-logs-claims email --audit-logs-claims username\"",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "bound_client_ids": {
          "description": "OAuth2 client IDs to restrict access",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "bound_ips": {
          "description": "CIDR whitelist for access",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "cert": {
          "description": "CertificateFile Path to a file that contain the certificate in a PEM format.",
          "type": "string"
        },
        "cert_file_data": {
          "description": "CertificateFileData PEM Certificate in a Base64 format.",
          "type": "string"
        },
        "delete_protection": {
          "description": "Enable delete protection",
          "type": "boolean"
        },
        "description": {
          "description": "Auth Method description",
          "type": "string"
        },
        "expiration_event_in": {
          "description": "How many days before the expiration of the auth method would you like to be notified.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "force_sub_claims": {
          "description": "Force sub-claims enforcement",
          "type": "boolean"
        },
        "gateway_url": {
          "description": "Akeyless Gateway URL (Configuration Management port). Relevant only when the jwks-uri is accessible only from the gateway.",
          "type": "string"
        },
        "gw_bound_ips": {
          "description": "Gateway CIDR whitelist",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "issuer": {
          "description": "OAuth2 issuer URL",
          "type": "string"
        },
        "jwks_json_data": {
          "description": "JWKS JSON data for token verification",
          "type": "string"
        },
        "jwks_uri": {
          "description": "JWKS URI for token verification",
          "type": "string"
        },
        "jwt_ttl": {
          "default": 0,
          "description": "JWT TTL in seconds",
          "type": "integer"
        },
        "name": {
          "description": "Auth Method name",
          "minLength": 1,
          "type": "string"
        },
        "product_type": {
          "description": "Choose the relevant product type for the auth method [sm, sra, pm, dp, ca]",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "subclaims_delimiters": {
          "description": "A list of additional sub claims delimiters (relevant only for SAML, OIDC, OAuth2/JWT)",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "unique_identifier": {
          "description": "Unique identifier claim name in the JWT token",
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "name",
        "unique_identifier"
      ],
      "type": "object"
    },
    "image": {
      "properties": {
        "pullPolicy": {
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "monitoring": {
      "properties": {
        "alerting": {
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "enabled": {
          "type": "boolean"
        },
        "interval": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "port": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "networkPolicy": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "pdb": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "ports": {
      "items": {
        "properties": {
          "containerPort": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "protocol": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "type": "array"
    },
    "replicaCount": {
      "default": 1,
      "type": "integer"
    },
    "resources": {
      "properties": {
        "limits": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "requests": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "service": {
      "properties": {
        "ports": {
          "items": {
            "properties": {
              "name": {
                "type": "string"
              },
              "port": {
                "type": "integer"
              },
              "protocol": {
                "type": "string"
              },
              "targetPort": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "type": "array"
        },
        "type": {
          "enum": [
            "ClusterIP",
            "NodePort",
            "LoadBalancer"
          ],
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "title": "akeyless_auth_method_oauth2 values",
  "type": "object"
}