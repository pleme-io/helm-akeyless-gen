{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "autoscaling": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "config": {
      "properties": {
        "audience": {
          "description": "Splunk token audience (required when using token authentication for rotation)",
          "type": "string"
        },
        "description": {
          "description": "Target description",
          "type": "string"
        },
        "key": {
          "description": "The name of a key that used to encrypt the target secret value (if empty, the account default protectionKey key will be used)",
          "type": "string"
        },
        "max_versions": {
          "description": "Set the maximum number of versions, limited by the account settings defaults.",
          "type": "string"
        },
        "name": {
          "description": "Target name",
          "type": "string"
        },
        "token_owner": {
          "description": "Splunk Token Owner (required when using token authentication for rotation)",
          "type": "string"
        },
        "url": {
          "description": "Splunk server URL",
          "type": "string"
        },
        "use_tls": {
          "default": true,
          "description": "Use TLS certificate verification when connecting to the Splunk management API",
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "url"
      ],
      "type": "object"
    },
    "image": {
      "properties": {
        "pullPolicy": {
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "monitoring": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "networkPolicy": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "pdb": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "replicaCount": {
      "default": 1,
      "type": "integer"
    },
    "resources": {
      "properties": {
        "limits": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "requests": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    }
  },
  "title": "akeyless_target_splunk values",
  "type": "object"
}