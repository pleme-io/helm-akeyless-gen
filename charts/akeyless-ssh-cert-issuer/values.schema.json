{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "autoscaling": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "config": {
      "properties": {
        "ProviderType": {
          "type": "string"
        },
        "allowed_users": {
          "default": "-",
          "description": "Users allowed to fetch the certificate, e.g. root,ubuntu",
          "type": "string"
        },
        "delete_protection": {
          "description": "Enable delete protection",
          "type": "boolean"
        },
        "description": {
          "description": "Description of the object",
          "type": "string"
        },
        "extensions": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Signed certificates with extensions, e.g. permit-port-forwarding",
          "type": "object"
        },
        "external_username": {
          "default": "false",
          "description": "Externally provided username [true/false]",
          "type": "string"
        },
        "fixed_user_claim_keyname": {
          "description": "Key-name of IdP claim to extract username from (for external-username=true)",
          "type": "string"
        },
        "host_provider": {
          "description": "Host provider type [explicit/target]",
          "type": "string"
        },
        "name": {
          "description": "SSH certificate issuer name",
          "type": "string"
        },
        "principals": {
          "description": "Signed certificates with principal, e.g. example_role1,example_role2",
          "type": "string"
        },
        "secure_access_use_internal_ssh_access": {
          "description": "Use internal SSH Access",
          "type": "boolean"
        },
        "signer_key_name": {
          "description": "Key to sign the certificate with",
          "type": "string"
        },
        "tag": {
          "description": "Tags for the SSH cert issuer",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "target": {
          "description": "A list of linked targets to be associated, Relevant only for Secure Remote Access for ssh cert issuer, ldap rotated secret and ldap dynamic secret, To specify multiple targets use argument multiple times",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "ttl": {
          "description": "Certificate TTL in seconds",
          "type": "integer"
        }
      },
      "required": [
        "allowed_users",
        "name",
        "signer_key_name",
        "ttl"
      ],
      "type": "object"
    },
    "image": {
      "properties": {
        "pullPolicy": {
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "monitoring": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "networkPolicy": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "pdb": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "replicaCount": {
      "default": 1,
      "type": "integer"
    },
    "resources": {
      "properties": {
        "limits": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "requests": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    }
  },
  "title": "akeyless_ssh_cert_issuer values",
  "type": "object"
}