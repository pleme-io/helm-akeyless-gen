{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "autoscaling": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "config": {
      "properties": {
        "description": {
          "description": "Description of the group",
          "type": "string"
        },
        "group_alias": {
          "description": "A short group alias",
          "type": "string"
        },
        "name": {
          "description": "Group name",
          "type": "string"
        },
        "user_assignment": {
          "description": "JSON string defining access permission assignment",
          "type": "string"
        }
      },
      "required": [
        "group_alias",
        "name"
      ],
      "type": "object"
    },
    "image": {
      "properties": {
        "pullPolicy": {
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "monitoring": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "networkPolicy": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "pdb": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "replicaCount": {
      "default": 1,
      "type": "integer"
    },
    "resources": {
      "properties": {
        "limits": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "requests": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    }
  },
  "title": "akeyless_group values",
  "type": "object"
}