{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "autoscaling": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "config": {
      "properties": {
        "delete_protection": {
          "description": "Enable delete protection",
          "type": "boolean"
        },
        "description": {
          "description": "Description of the object",
          "type": "string"
        },
        "gke_cluster_endpoint": {
          "description": "GKE cluster API server URL",
          "type": "string"
        },
        "gke_cluster_name": {
          "description": "GKE cluster name",
          "type": "string"
        },
        "gke_service_account_email": {
          "description": "GCP service account email",
          "type": "string"
        },
        "item_custom_fields": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Additional custom fields to associate with the item",
          "type": "object"
        },
        "name": {
          "description": "Dynamic secret name",
          "type": "string"
        },
        "producer_encryption_key_name": {
          "description": "Dynamic producer encryption key",
          "type": "string"
        },
        "secure_access_allow_port_forwading": {
          "description": "Enable Port forwarding while using CLI access",
          "type": "boolean"
        },
        "secure_access_cluster_endpoint": {
          "description": "The K8s cluster endpoint URL",
          "type": "string"
        },
        "secure_access_delay": {
          "description": "The delay duration, in seconds, to wait after generating just-in-time credentials. Accepted range: 0-120 seconds",
          "type": "integer"
        },
        "tags": {
          "description": "Tags for the producer",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "target_name": {
          "description": "Target name associated with this producer",
          "type": "string"
        },
        "user_ttl": {
          "default": "60m",
          "description": "User TTL (e.g., 60m, 12h)",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "image": {
      "properties": {
        "pullPolicy": {
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "monitoring": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "networkPolicy": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "pdb": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "replicaCount": {
      "default": 1,
      "type": "integer"
    },
    "resources": {
      "properties": {
        "limits": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "requests": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "secrets": {
      "properties": {
        "gke_account_key": {
          "description": "GCP service account key JSON (base64)",
          "type": "string"
        },
        "gke_cluster_cert": {
          "description": "GKE cluster CA certificate (PEM)",
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "title": "akeyless_dynamic_secret_gke values",
  "type": "object"
}