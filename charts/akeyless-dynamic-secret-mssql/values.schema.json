{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "autoscaling": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "config": {
      "properties": {
        "custom_username_template": {
          "description": "Customize how temporary usernames are generated using go template",
          "type": "string"
        },
        "delete_protection": {
          "description": "Enable delete protection",
          "type": "boolean"
        },
        "description": {
          "description": "Description of the object",
          "type": "string"
        },
        "item_custom_fields": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Additional custom fields to associate with the item",
          "type": "object"
        },
        "mssql_allowed_db_names": {
          "description": "CSV of allowed DB names for runtime selection when getting the secret value.\nEmpty => use target DB only; \"*\" => any DB allowed; One or more names => user must choose from this list",
          "type": "string"
        },
        "mssql_create_statements": {
          "description": "MSSQL Creation statements",
          "type": "string"
        },
        "mssql_dbname": {
          "description": "MSSQL database name",
          "type": "string"
        },
        "mssql_host": {
          "default": "127.0.0.1",
          "description": "MSSQL host",
          "type": "string"
        },
        "mssql_port": {
          "default": "1433",
          "description": "MSSQL port (default: 1433)",
          "type": "string"
        },
        "mssql_revocation_statements": {
          "description": "MSSQL revocation statements",
          "type": "string"
        },
        "mssql_username": {
          "description": "MSSQL admin username",
          "type": "string"
        },
        "name": {
          "description": "Dynamic secret name",
          "type": "string"
        },
        "password_length": {
          "description": "The length of the password to be generated",
          "type": "string"
        },
        "producer_encryption_key_name": {
          "description": "Dynamic producer encryption key",
          "type": "string"
        },
        "secure_access_delay": {
          "description": "The delay duration, in seconds, to wait after generating just-in-time credentials. Accepted range: 0-120 seconds",
          "type": "integer"
        },
        "tags": {
          "description": "Tags for the producer",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "target_name": {
          "description": "Target name associated with this producer",
          "type": "string"
        },
        "user_ttl": {
          "default": "60m",
          "description": "User TTL (e.g., 60m, 12h)",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "image": {
      "properties": {
        "pullPolicy": {
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "monitoring": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "networkPolicy": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "pdb": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "replicaCount": {
      "default": 1,
      "type": "integer"
    },
    "resources": {
      "properties": {
        "limits": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "requests": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "secrets": {
      "properties": {
        "mssql_password": {
          "description": "MSSQL admin password",
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "title": "akeyless_dynamic_secret_mssql values",
  "type": "object"
}