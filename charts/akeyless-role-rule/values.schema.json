{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "autoscaling": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "config": {
      "properties": {
        "capability": {
          "description": "Permission capability: read, create, update, delete, list, deny",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "path": {
          "description": "Item path the rule applies to",
          "type": "string"
        },
        "role_name": {
          "description": "Role name to attach the rule to",
          "type": "string"
        },
        "rule_type": {
          "default": "item-rule",
          "description": "Rule type: item-rule or auth-method-rule or role-rule",
          "type": "string"
        },
        "ttl": {
          "description": "RoleRule ttl",
          "type": "integer"
        }
      },
      "required": [
        "capability",
        "path",
        "role_name"
      ],
      "type": "object"
    },
    "image": {
      "properties": {
        "pullPolicy": {
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "monitoring": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "networkPolicy": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "pdb": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "replicaCount": {
      "default": 1,
      "type": "integer"
    },
    "resources": {
      "properties": {
        "limits": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "requests": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    }
  },
  "title": "akeyless_role_rule values",
  "type": "object"
}