{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "autoscaling": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "config": {
      "properties": {
        "bind_dn": {
          "description": "LDAP bind DN",
          "type": "string"
        },
        "description": {
          "description": "Target description",
          "type": "string"
        },
        "key": {
          "description": "The name of a key that used to encrypt the target secret value (if empty, the account default protectionKey key will be used)",
          "type": "string"
        },
        "ldap_ca_cert": {
          "description": "CA Certificate File Content",
          "type": "string"
        },
        "ldap_url": {
          "description": "LDAP server URL (e.g., ldap://host:389)",
          "type": "string"
        },
        "max_versions": {
          "description": "Set the maximum number of versions, limited by the account settings defaults.",
          "type": "string"
        },
        "name": {
          "description": "Target name",
          "type": "string"
        },
        "server_type": {
          "default": "OpenLDAP",
          "description": "Set Ldap server type, Options:[OpenLDAP, ActiveDirectory]. Default is OpenLDAP",
          "type": "string"
        },
        "token_expiration": {
          "description": "LDAP token expiration in seconds",
          "type": "string"
        }
      },
      "required": [
        "bind_dn",
        "ldap_url",
        "name"
      ],
      "type": "object"
    },
    "image": {
      "properties": {
        "pullPolicy": {
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "monitoring": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "networkPolicy": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "pdb": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "replicaCount": {
      "default": 1,
      "type": "integer"
    },
    "resources": {
      "properties": {
        "limits": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "requests": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "secrets": {
      "properties": {
        "bind_dn_password": {
          "description": "LDAP bind DN password",
          "type": "string"
        }
      },
      "required": [
        "bind_dn_password"
      ],
      "type": "object"
    }
  },
  "title": "akeyless_target_ldap values",
  "type": "object"
}