{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "autoscaling": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "config": {
      "properties": {
        "connection_type": {
          "default": "credentials",
          "description": "Type of connection to Windows Server [credentials/parent-target]",
          "type": "string"
        },
        "description": {
          "description": "Target description",
          "type": "string"
        },
        "domain": {
          "description": "Windows domain",
          "type": "string"
        },
        "hostname": {
          "description": "Windows host address",
          "minLength": 1,
          "type": "string"
        },
        "key": {
          "description": "The name of a key that used to encrypt the target secret value (if empty, the account default protectionKey key will be used)",
          "type": "string"
        },
        "max_versions": {
          "description": "Set the maximum number of versions, limited by the account settings defaults.",
          "type": "string"
        },
        "name": {
          "description": "Target name",
          "minLength": 1,
          "type": "string"
        },
        "parent_target_name": {
          "description": "Name of the parent target, relevant only when connection-type is parent-target",
          "type": "string"
        },
        "port": {
          "default": "5986",
          "description": "WinRM port (default: 5986)",
          "type": "string"
        },
        "use_tls": {
          "default": "true",
          "description": "Use TLS for WinRM connection",
          "type": "boolean"
        }
      },
      "required": [
        "hostname",
        "name"
      ],
      "type": "object"
    },
    "image": {
      "properties": {
        "pullPolicy": {
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "monitoring": {
      "properties": {
        "alerting": {
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "enabled": {
          "type": "boolean"
        },
        "interval": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "port": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "networkPolicy": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "pdb": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "ports": {
      "items": {
        "properties": {
          "containerPort": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "protocol": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "type": "array"
    },
    "replicaCount": {
      "default": 1,
      "type": "integer"
    },
    "resources": {
      "properties": {
        "limits": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "requests": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "secrets": {
      "properties": {
        "certificate": {
          "description": "Client certificate (PEM)",
          "type": "string"
        }
      },
      "type": "object"
    },
    "service": {
      "properties": {
        "ports": {
          "items": {
            "properties": {
              "name": {
                "type": "string"
              },
              "port": {
                "type": "integer"
              },
              "protocol": {
                "type": "string"
              },
              "targetPort": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "type": "array"
        },
        "type": {
          "enum": [
            "ClusterIP",
            "NodePort",
            "LoadBalancer"
          ],
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "title": "akeyless_target_windows values",
  "type": "object"
}