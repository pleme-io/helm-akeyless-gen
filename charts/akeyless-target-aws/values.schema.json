{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "autoscaling": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "config": {
      "properties": {
        "description": {
          "description": "Target description",
          "type": "string"
        },
        "generate_external_id": {
          "description": "A unique auto-generated value used in your AWS account when configuring your AWS IAM role to securely delegate access to Akeyless. Relevant only when using GW cloud ID",
          "type": "boolean"
        },
        "key": {
          "description": "The name of a key that used to encrypt the target secret value (if empty, the account default protectionKey key will be used)",
          "type": "string"
        },
        "max_versions": {
          "description": "Set the maximum number of versions, limited by the account settings defaults.",
          "type": "string"
        },
        "name": {
          "description": "Target name",
          "type": "string"
        },
        "region": {
          "default": "us-east-2",
          "description": "AWS region",
          "type": "string"
        },
        "role_arn": {
          "description": "AWS IAM role identifier that Gateway will assume in your AWS account, relevant only when using external ID",
          "type": "string"
        },
        "use_gw_cloud_identity": {
          "description": "Use gateway cloud identity for authentication",
          "type": "boolean"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "image": {
      "properties": {
        "pullPolicy": {
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "monitoring": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "networkPolicy": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "pdb": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "replicaCount": {
      "default": 1,
      "type": "integer"
    },
    "resources": {
      "properties": {
        "limits": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "requests": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "secrets": {
      "properties": {
        "access_key": {
          "description": "AWS secret access key",
          "type": "string"
        },
        "access_key_id": {
          "description": "AWS access key ID",
          "type": "string"
        },
        "session_token": {
          "description": "AWS session token (for temporary credentials)",
          "type": "string"
        }
      },
      "required": [
        "access_key",
        "access_key_id"
      ],
      "type": "object"
    }
  },
  "title": "akeyless_target_aws values",
  "type": "object"
}