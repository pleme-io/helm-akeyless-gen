{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "autoscaling": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "config": {
      "properties": {
        "custom_username_template": {
          "description": "Customize how temporary usernames are generated using go template",
          "type": "string"
        },
        "delete_protection": {
          "description": "Enable delete protection",
          "type": "boolean"
        },
        "description": {
          "description": "Description of the object",
          "type": "string"
        },
        "item_custom_fields": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Additional custom fields to associate with the item",
          "type": "object"
        },
        "k8s_allowed_namespaces": {
          "description": "Allowed Kubernetes namespaces (comma-separated)",
          "type": "string"
        },
        "k8s_cluster_endpoint": {
          "description": "Kubernetes API server URL",
          "type": "string"
        },
        "k8s_cluster_name": {
          "description": "K8S cluster name",
          "type": "string"
        },
        "k8s_namespace": {
          "description": "Kubernetes namespace",
          "type": "string"
        },
        "k8s_predefined_role_name": {
          "description": "The pre-existing Role or ClusterRole name to bind the generated ServiceAccount to (relevant only for k8s-service-account-type=dynamic)",
          "type": "string"
        },
        "k8s_predefined_role_type": {
          "description": "Specifies the type of the pre-existing K8S role [Role, ClusterRole] (relevant only for k8s-service-account-type=dynamic)",
          "type": "string"
        },
        "k8s_rolebinding_yaml_data": {
          "description": "Content of the yaml in a Base64 format.",
          "type": "string"
        },
        "k8s_rolebinding_yaml_def": {
          "description": "Path to yaml file that contains definitions of K8S role and role binding (relevant only for k8s-service-account-type=dynamic)",
          "type": "string"
        },
        "k8s_service_account": {
          "description": "Kubernetes service account name",
          "type": "string"
        },
        "k8s_service_account_type": {
          "description": "K8S ServiceAccount type [fixed, dynamic].",
          "type": "string"
        },
        "name": {
          "description": "Dynamic secret name",
          "type": "string"
        },
        "producer_encryption_key_name": {
          "description": "Dynamic producer encryption key",
          "type": "string"
        },
        "secure_access_allow_port_forwading": {
          "description": "Enable Port forwarding while using CLI access",
          "type": "boolean"
        },
        "secure_access_cluster_endpoint": {
          "description": "The K8s cluster endpoint URL",
          "type": "string"
        },
        "secure_access_dashboard_url": {
          "description": "The K8s dashboard url",
          "type": "string"
        },
        "secure_access_delay": {
          "description": "The delay duration, in seconds, to wait after generating just-in-time credentials. Accepted range: 0-120 seconds",
          "type": "integer"
        },
        "tags": {
          "description": "Tags for the producer",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "target_name": {
          "description": "Target name associated with this producer",
          "type": "string"
        },
        "use_gw_service_account": {
          "description": "Use the GW's service account",
          "type": "boolean"
        },
        "user_ttl": {
          "default": "60m",
          "description": "User TTL (e.g., 60m, 12h)",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "image": {
      "properties": {
        "pullPolicy": {
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "monitoring": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "networkPolicy": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "pdb": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "replicaCount": {
      "default": 1,
      "type": "integer"
    },
    "resources": {
      "properties": {
        "limits": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "requests": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "secrets": {
      "properties": {
        "k8s_cluster_ca_cert": {
          "description": "Kubernetes cluster CA certificate (PEM)",
          "type": "string"
        },
        "k8s_cluster_token": {
          "description": "Kubernetes bearer token",
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "title": "akeyless_dynamic_secret_k8s values",
  "type": "object"
}