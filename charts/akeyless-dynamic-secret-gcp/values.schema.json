{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "autoscaling": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "config": {
      "properties": {
        "access_type": {
          "type": "string"
        },
        "custom_username_template": {
          "description": "Customize how temporary usernames are generated using go template",
          "type": "string"
        },
        "delete_protection": {
          "description": "Enable delete protection",
          "type": "boolean"
        },
        "description": {
          "description": "Description of the object",
          "type": "string"
        },
        "fixed_user_claim_keyname": {
          "default": "ext_email",
          "description": "For externally provided users, denotes the key-name of IdP claim to extract the username from (Relevant only when --access-type=external)",
          "type": "string"
        },
        "gcp_cred_type": {
          "description": "GCP credential type: token or key",
          "type": "string"
        },
        "gcp_key": {
          "description": "Base64-encoded service account private key text",
          "type": "string"
        },
        "gcp_key_algo": {
          "description": "GCP service account key algorithm",
          "type": "string"
        },
        "gcp_project_id": {
          "description": "GCP Project ID override for dynamic secret operations",
          "type": "string"
        },
        "gcp_sa_email": {
          "description": "GCP service account email",
          "type": "string"
        },
        "gcp_token_scopes": {
          "description": "GCP access token scopes (comma-separated)",
          "type": "string"
        },
        "item_custom_fields": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Additional custom fields to associate with the item",
          "type": "object"
        },
        "name": {
          "description": "Dynamic secret name",
          "type": "string"
        },
        "producer_encryption_key_name": {
          "description": "Dynamic producer encryption key",
          "type": "string"
        },
        "role_binding": {
          "description": "Role binding in the format Role,Resource",
          "type": "string"
        },
        "role_names": {
          "description": "Comma-separated list of GCP roles to assign to the user (Relevant only when --access-type=external)",
          "type": "string"
        },
        "secure_access_delay": {
          "description": "The delay duration, in seconds, to wait after generating just-in-time credentials. Accepted range: 0-120 seconds",
          "type": "integer"
        },
        "service_account_type": {
          "default": "fixed",
          "description": "Service account type: fixed or dynamic",
          "type": "string"
        },
        "tags": {
          "description": "Tags for the producer",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "target_name": {
          "description": "Target name associated with this producer",
          "type": "string"
        },
        "user_ttl": {
          "default": "60m",
          "description": "User TTL (e.g., 60m, 12h)",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "image": {
      "properties": {
        "pullPolicy": {
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "monitoring": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "networkPolicy": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "pdb": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "replicaCount": {
      "default": 1,
      "type": "integer"
    },
    "resources": {
      "properties": {
        "limits": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "requests": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    }
  },
  "title": "akeyless_dynamic_secret_gcp values",
  "type": "object"
}