{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "autoscaling": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "config": {
      "properties": {
        "description": {
          "description": "Target description",
          "type": "string"
        },
        "eks_cluster_endpoint": {
          "description": "EKS cluster API server URL",
          "type": "string"
        },
        "eks_cluster_name": {
          "description": "EKS cluster name",
          "type": "string"
        },
        "eks_region": {
          "default": "us-east-2",
          "description": "AWS region for EKS cluster",
          "type": "string"
        },
        "key": {
          "description": "The name of a key that used to encrypt the target secret value (if empty, the account default protectionKey key will be used)",
          "type": "string"
        },
        "max_versions": {
          "description": "Set the maximum number of versions, limited by the account settings defaults.",
          "type": "string"
        },
        "name": {
          "description": "Target name",
          "type": "string"
        },
        "use_gw_cloud_identity": {
          "description": "Use gateway cloud identity for authentication",
          "type": "boolean"
        }
      },
      "required": [
        "eks_cluster_endpoint",
        "eks_cluster_name",
        "name"
      ],
      "type": "object"
    },
    "image": {
      "properties": {
        "pullPolicy": {
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ],
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "monitoring": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "networkPolicy": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "pdb": {
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "replicaCount": {
      "default": 1,
      "type": "integer"
    },
    "resources": {
      "properties": {
        "limits": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "requests": {
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "secrets": {
      "properties": {
        "eks_access_key_id": {
          "description": "AWS access key ID for EKS",
          "type": "string"
        },
        "eks_cluster_ca_cert": {
          "description": "EKS cluster CA certificate (PEM)",
          "type": "string"
        },
        "eks_secret_access_key": {
          "description": "AWS secret access key for EKS",
          "type": "string"
        }
      },
      "required": [
        "eks_access_key_id",
        "eks_cluster_ca_cert",
        "eks_secret_access_key"
      ],
      "type": "object"
    }
  },
  "title": "akeyless_target_eks values",
  "type": "object"
}